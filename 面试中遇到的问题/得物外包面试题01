CREATE TABLE t_login (
    user_id INT,
    login_time DATETIME
);
INSERT INTO t_login (user_id, login_time)
SELECT 
    FLOOR(1 + RAND() * 1000) AS user_id,  -- 随机用户ID (1-10)
    TIMESTAMPADD(
        SECOND,
        FLOOR(RAND() * 2592000),  -- 随机秒数 (0~1.69亿秒≈5.36年)
        '2025-05-01 00:00:00'
    ) AS login_time
FROM 
    (SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5) a  -- 生成100行的笛卡尔积
    JOIN (SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5) b
    JOIN (SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4) c
    JOIN (SELECT 1 UNION SELECT 2) d
LIMIT 5000;
truncate table t_login;
select * from t_login;

with tmp1 as(
select user_id,
       date_format(login_time,'%Y-%m-%d') login_date
from t_login
group by 1,2
order by 1,2
),
tmp2 as(
select user_id,
       min(login_date) first_login
from tmp1
group by user_id
)
select first_login,
       sum(if(first_login=login_date,1,0)) incre_user_cnt,
       sum(if(first_login=login_date-interval 1 day,1,0)) one_user_cnt,
       sum(if(first_login=login_date-interval 3 day,1,0)) three_user_cnt,
       sum(if(first_login=login_date-interval 7 day,1,0)) seven_user_cnt,
       sum(if(first_login=login_date-interval 14 day,1,0)) fourteen_user_cnt,
			 round(sum(if(first_login=login_date-interval 1 day,1,0))/
			 sum(if(first_login=login_date,1,0)),2) 次日留存,
			 round(sum(if(first_login=login_date-interval 3 day,1,0))/
			 sum(if(first_login=login_date,1,0)),2) '3日留存',
			 round(sum(if(first_login=login_date-interval 7 day,1,0))/
			 sum(if(first_login=login_date,1,0)),2) '7日留存',
			 round(sum(if(first_login=login_date-interval 14 day,1,0))/
			 sum(if(first_login=login_date,1,0)),2) '14日留存'
from tmp2 t2 left join tmp1 t1
on t2.user_id=t1.user_id
group by first_login
order by first_login;

with tmp1 as(
select user_id,
       date_format(login_time,'%Y-%m-%d') login_date
from t_login
group by 1,2
order by 1,2
),
tmp2 as(
select user_id,
       min(login_date) first_login
from tmp1
group by user_id
)
select first_login,
       count(distinct t2.user_id) incre_user_cnt, -- 修正：新增人数改为去重计数
       count(distinct if(t1.login_date = t2.first_login + interval 1 day, t2.user_id, null)) one_user_cnt,
       count(distinct if(t1.login_date = t2.first_login + interval 3 day, t2.user_id, null)) three_user_cnt,
       count(distinct if(t1.login_date = t2.first_login + interval 7 day, t2.user_id, null)) seven_user_cnt,
       count(distinct if(t1.login_date = t2.first_login + interval 14 day, t2.user_id, null)) fourteen_user_cnt,
       round(count(distinct if(t1.login_date = t2.first_login + interval 1 day, t2.user_id, null))/count(distinct t2.user_id),2) 次日留存,
       round(count(distinct if(t1.login_date = t2.first_login + interval 3 day, t2.user_id, null))/count(distinct t2.user_id),2) '3日留存',
       round(count(distinct if(t1.login_date = t2.first_login + interval 7 day, t2.user_id, null))/count(distinct t2.user_id),2) '7日留存',
       round(count(distinct if(t1.login_date = t2.first_login + interval 14 day, t2.user_id, null))/count(distinct t2.user_id),2) '14日留存'
from tmp2 t2 left join tmp1 t1
on t2.user_id=t1.user_id
group by first_login
order by first_login;

with tmp1 as(
select user_id,
       date_format(login_time,'%Y-%m-%d') login_date
from t_login
group by 1,2
),
tmp2 as(
select user_id,
       min(login_date) first_login
from tmp1
group by user_id
),
tmp3 as(
select user_id,
       login_date,
			 row_number()over(partition by user_id order by login_date) pm
from tmp1
),
tmp4 as(
select user_id
from tmp3 
group by user_id,login_date-interval pm day
having count(*)>=3
)
select first_login,
       count(t2.user_id) incre_user_cnt,
			 count(t4.user_id) three_user_cont,
			 round(count(t4.user_id)/count(t2.user_id),2) three_liucun_ratio
from tmp2 t2 left join tmp4 t4
on t2.user_id=t4.user_id
group by first_login 
order by first_login;



